{
	"openapi": "3.0.0",
	"components": {
		"examples": {},
		"headers": {},
		"parameters": {},
		"requestBodies": {},
		"responses": {},
		"schemas": {
			"RateQuote": {
				"properties": {
					"carrier": {
						"type": "string"
					},
					"service": {
						"type": "string"
					},
					"amount": {
						"type": "number",
						"format": "double"
					},
					"currency": {
						"type": "string"
					},
					"deliveryDays": {
						"type": "number",
						"format": "double"
					}
				},
				"required": [
					"carrier",
					"service",
					"amount",
					"currency"
				],
				"type": "object",
				"additionalProperties": false
			},
			"Address": {
				"properties": {
					"postalCode": {
						"type": "string"
					},
					"country": {
						"type": "string"
					}
				},
				"required": [
					"postalCode",
					"country"
				],
				"type": "object",
				"additionalProperties": false
			},
			"Package": {
				"properties": {
					"weight": {
						"type": "number",
						"format": "double"
					}
				},
				"required": [
					"weight"
				],
				"type": "object",
				"additionalProperties": false
			},
			"RateRequest": {
				"properties": {
					"carrier": {
						"type": "string"
					},
					"origin": {
						"$ref": "#/components/schemas/Address"
					},
					"destination": {
						"$ref": "#/components/schemas/Address"
					},
					"packages": {
						"items": {
							"$ref": "#/components/schemas/Package"
						},
						"type": "array"
					}
				},
				"required": [
					"origin",
					"destination",
					"packages"
				],
				"type": "object",
				"additionalProperties": false
			}
		},
		"securitySchemes": {}
	},
	"info": {
		"title": "cybership-shipping-service",
		"version": "1.0.0",
		"contact": {}
	},
	"paths": {
		"/shipping/rates": {
			"post": {
				"operationId": "GetRates",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"items": {
										"$ref": "#/components/schemas/RateQuote"
									},
									"type": "array"
								}
							}
						}
					}
				},
				"tags": [
					"Shipping"
				],
				"security": [],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/RateRequest"
							}
						}
					}
				}
			}
		}
	},
	"servers": [
		{
			"url": "/"
		}
	]
}